pipeline {
    agent any

    environment {
        STACK = "flask"
        USER = "test"
        IMAGE_NAME = "vinayvb18/${STACK}-env"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Clone Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/vinay592/SPE_Intelligent-Ephemeral-Multi-Stack-Dev-Platform.git'
            }
        }

        // ✅ ANSIBLE (SAFE VERSION)
        stage('Setup Infra (Ansible)') {
            steps {
                sh '''
                echo "Running Ansible setup..."

                # ensure docker running
                sudo systemctl start docker || true
                sudo chmod 666 /var/run/docker.sock || true

                # run ansible but don't fail pipeline
                ansible-playbook ansible/setup.yml || true
                '''
            }
        }

        // ✅ FIXED PYTHON ENV (NO PIP BUG)
        stage('Setup Backend Environment') {
            steps {
                dir('backend') {
                    sh '''
                    python3 -m venv venv

                    # REMOVE BROKEN PIP COMPLETELY
                    rm -rf venv/lib/python3.12/site-packages/pip*

                    # REINSTALL CLEAN PIP
                    curl -sS https://bootstrap.pypa.io/get-pip.py | venv/bin/python

                    # INSTALL REQUIREMENTS
                    venv/bin/pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Start ELK Monitoring') {
            steps {
                sh '''
                docker-compose up -d
                '''
            }
        }

        stage('Ensure Mongo Ready') {
            steps {
                sh '''
                minikube status || minikube start --driver=docker

                kubectl apply -f k8s/config.yml
                kubectl apply -f k8s/secrets.yml
                kubectl apply -f k8s/mongo.yaml

                for i in {1..30}
                do
                    status=$(kubectl get pods -n dev-platform -l app=mongo -o jsonpath="{.items[0].status.phase}" 2>/dev/null || echo "NotReady")

                    if [ "$status" = "Running" ]
                    then
                        echo "Mongo ready"
                        break
                    fi

                    sleep 3
                done

                pkill -f "kubectl port-forward" || true

                nohup kubectl port-forward svc/mongo-svc 27017:27017 -n dev-platform > mongo.log 2>&1 &
                sleep 5
                '''
            }
        }

        stage('Start & Test Backend') {
            steps {
                dir('backend') {
                    sh '''
                    pkill -f "app.py" || true

                    nohup venv/bin/python app.py > ../backend.log 2>&1 &

                    for i in {1..15}
                    do
                        if curl -s http://localhost:5001/ > /dev/null
                        then
                            echo "Backend ready"
                            break
                        fi
                        sleep 2
                    done

                    curl -s -X POST http://localhost:5001/signup \
                    -H "Content-Type: application/json" \
                    -d '{"username":"testuser","password":"123"}' > /dev/null || true

                    login_res=$(curl -s -X POST http://localhost:5001/login \
                    -H "Content-Type: application/json" \
                    -d '{"username":"testuser","password":"123"}')

                    echo "$login_res" | grep '"status": true' || exit 1
                    '''
                }
            }
        }

        stage('Build & Push Image') {
            steps {
                withCredentials([string(credentialsId: 'docker-pass', variable: 'DOCKER_PASS')]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u vinayvb18 --password-stdin
                    docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} templates/${STACK}
                    docker push ${IMAGE_NAME}:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                curl -X POST http://localhost:5001/create-env \
                -H "Content-Type: application/json" \
                -d '{"stack":"flask","user":"test"}'
                '''
            }
        }
    }

    post {
        success {
            echo "SUCCESS ✅"
        }
        failure {
            echo "FAILED ❌"
        }
    }
}
