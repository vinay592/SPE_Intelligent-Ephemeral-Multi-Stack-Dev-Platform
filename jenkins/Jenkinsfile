pipeline {
    agent any

    environment {
        STACK = "flask"
        USER = "test"
        IMAGE_NAME = "vinayvb18/${STACK}-env"
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/vinay592/SPE_Intelligent-Ephemeral-Multi-Stack-Dev-Platform.git'
            }
        }

        stage('Setup Backend Environment') {
    steps {
        dir('backend') {
            sh '''
                python3 -m venv venv

                # fix pip corruption
                venv/bin/python -m ensurepip --upgrade

                # upgrade properly
                venv/bin/python -m pip install --upgrade pip setuptools wheel

                # install deps
                venv/bin/pip install -r requirements.txt
            '''
        }
    }
}

        // 🔥 FIXED: ENSURE MINIKUBE + MONGO
        stage('Ensure Mongo Ready') {
            steps {
                sh '''
                echo "Checking Minikube..."

                minikube status || minikube start --driver=docker

                echo "Applying Mongo..."
                kubectl apply -f k8s/mongo.yaml

                echo "Waiting for Mongo pod..."

                for i in {1..30}
                do
                    status=$(kubectl get pods -n dev-platform -l app=mongo -o jsonpath="{.items[0].status.phase}" 2>/dev/null || echo "NotReady")

                    echo "Mongo status: $status"

                    if [ "$status" = "Running" ]
                    then
                        echo "Mongo is ready ✅"
                        break
                    fi

                    sleep 3
                done

                echo "Starting port-forward..."

                pkill -f "kubectl port-forward" || true

                nohup kubectl port-forward svc/mongo-svc 27017:27017 -n dev-platform > mongo.log 2>&1 &

                sleep 5
                '''
            }
        }

        // 🔥 FIXED: BACKEND START + TEST
        stage('Start & Test Backend') {
            steps {
                dir('backend') {
                    sh '''
                    echo "Starting backend..."

                    pkill -f "app.py" || true

                    nohup venv/bin/python app.py > ../backend.log 2>&1 &

                    echo "Waiting for backend..."

                    for i in {1..15}
                    do
                        if curl -s http://localhost:5001/ > /dev/null
                        then
                            echo "Backend ready ✅"
                            break
                        fi
                        sleep 2
                    done

                    echo "Running API tests..."

                    curl -s -X POST http://localhost:5001/signup \
                    -H "Content-Type: application/json" \
                    -d '{"username":"testuser","password":"123"}' > /dev/null || true

                    login_res=$(curl -s -X POST http://localhost:5001/login \
                    -H "Content-Type: application/json" \
                    -d '{"username":"testuser","password":"123"}')

                    echo "Login response: $login_res"
                    echo "$login_res" | grep '"status": true' || exit 1

                    wrong_res=$(curl -s -X POST http://localhost:5001/login \
                    -H "Content-Type: application/json" \
                    -d '{"username":"testuser","password":"wrong"}')

                    echo "$wrong_res" | grep '"status": false' || exit 1

                    echo "Backend working ✅"
                    '''
                }
            }
        }

        stage('Build & Push Image') {
            steps {
                withCredentials([string(credentialsId: 'docker-pass', variable: 'DOCKER_PASS')]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u vinayvb18 --password-stdin
                    docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} templates/${STACK}
                    docker push ${IMAGE_NAME}:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Deploy (Ephemeral Env)') {
            steps {
                script {
                    def response = sh(
                        script: """
                        curl -s -X POST http://localhost:5001/create-env \
                        -H "Content-Type: application/json" \
                        -d '{"stack":"${STACK}", "user":"${USER}", "image":"${IMAGE_NAME}:${BUILD_NUMBER}"}'
                        """,
                        returnStdout: true
                    ).trim()

                    echo "Deployment Response:"
                    echo response
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                echo "Deployment done 🚀"
                minikube ip
                '''
            }
        }
    }

    post {
        success {
            echo "SUCCESS ✅"
        }
        failure {
            echo "FAILED ❌"
        }
    }
}
