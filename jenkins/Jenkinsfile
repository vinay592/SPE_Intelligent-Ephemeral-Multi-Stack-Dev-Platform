pipeline {
    agent any

    parameters {
        choice(
            name: 'STACK',
            choices: ['flask', 'mern', 'java', 'ml'],
            description: 'Choose stack'
        )
        string(
            name: 'USER_ID',
            defaultValue: 'vinay',
            description: 'Enter user name'
        )
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/vinay592/SPE_Intelligent-Ephemeral-Multi-Stack-Dev-Platform.git'
            }
        }

        stage('Ensure Backend Running') {
            steps {
                sh '''
                echo "Checking if backend is running..."

                if lsof -i:5001 | grep LISTEN
                then
                    echo "Backend already running ✅"
                else
                    echo "Starting backend 🚀"
                    nohup python3 backend/app.py > backend.log 2>&1 &

                    echo "Waiting for backend to be ready..."
                    for i in {1..10}
                    do
                        if curl -s http://localhost:5001 > /dev/null
                        then
                            echo "Backend is ready ✅"
                            break
                        fi
                        sleep 2
                    done
                fi
                '''
            }
        }

        stage('Set Minikube Docker Env + Build Image') {
            steps {
                sh '''
                eval $(minikube docker-env)
                docker build -t ${STACK}-env:v1 templates/${STACK}
                '''
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                sh '''
                echo "Running Trivy scan 🔐..."
                trivy image --severity HIGH,CRITICAL ${STACK}-env:v1 || true
                '''
            }
        }

        stage('Trigger Deployment') {
            steps {
                script {
                    def response = sh(
                        script: """
                        curl -s -X POST http://localhost:5001/create-env \
                        -H "Content-Type: application/json" \
                        -d '{"stack":"${params.STACK}", "user":"${params.USER_ID}"}'
                        """,
                        returnStdout: true
                    ).trim()

                    echo "📦 Deployment Response:"
                    echo "${response}"

                    def port = response.split('"access_port":')[1].split(',')[0].trim()
                    env.APP_PORT = port

                    echo "🚀 Environment Ready!"
                    echo "User: ${params.USER_ID}"
                    echo "Stack: ${params.STACK}"
                    echo "Port: ${port}"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    echo "Checking app health ❤️..."
                    sleep 5

                    // 🔥 FIXED: Use minikube service URL
                    def url = sh(
                        script: "minikube service ${params.USER_ID}-${params.STACK}-svc -n dev-platform --url",
                        returnStdout: true
                    ).trim()

                    echo "Service URL: ${url}"

                    sh "curl -f ${url}"
                }
            }
        }
    }

    post {
        success {
            mail to: 'vinayvb592@gmail.com',
                 subject: "SUCCESS: ${params.STACK}",
                 body: "Build + Deployment successful 🚀"
        }
        failure {
            mail to: 'vinayvb592@gmail.com',
                 subject: "FAILED: ${params.STACK}",
                 body: "Something went wrong ❌"
        }
    }
}
