pipeline {
    agent any

    parameters {
        choice(
            name: 'STACK',
            choices: ['flask', 'mern', 'java', 'ml'],
            description: 'Choose stack'
        )
    }

    stages {

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t ${params.STACK}-env:v1 templates/${params.STACK}
                """
            }
        }

        stage('Trigger Deployment') {
            steps {
                sh """
                curl -X POST http://localhost:5001/create-env \
                -H "Content-Type: application/json" \
                -d '{"stack":"${params.STACK}"}'
                """
            }
        }

        // ✅ ADD HERE (INSIDE stages)

        stage('Get Service URL') {
            steps {
                script {
                    def svcName = sh(
                        script: "kubectl get svc -n dev-platform --no-headers -o custom-columns=\":metadata.name\" | tail -n 1",
                        returnStdout: true
                    ).trim()

                    echo "Service Name: ${svcName}"

                    def nodePort = sh(
                        script: "kubectl get svc ${svcName} -n dev-platform -o jsonpath='{.spec.ports[0].nodePort}'",
                        returnStdout: true
                    ).trim()

                    echo "NodePort: ${nodePort}"

                    def minikubeIP = sh(
                        script: "minikube ip",
                        returnStdout: true
                    ).trim()

                    def url = "http://${minikubeIP}:${nodePort}"

                    echo "🚀 Application URL: ${url}"

                    sh """
                    xdg-open ${url} || echo "Open manually: ${url}"
                    """
                }
            }
        }
    }

    post {
        success {
            mail to: 'vinayvb592@gmail.com',
                 subject: "SUCCESS: ${params.STACK}",
                 body: "Build and deployment successful"
        }
        failure {
            mail to: 'vinayvb592@gmail.com',
                 subject: "FAILED: ${params.STACK}",
                 body: "Something went wrong"
        }
    }
}
