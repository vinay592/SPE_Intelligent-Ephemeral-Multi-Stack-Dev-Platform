pipeline {
    agent any

    parameters {
        choice(
            name: 'STACK',
            choices: ['flask', 'mern', 'java', 'ml'],
            description: 'Choose stack'
        )
        string(
            name: 'USER_ID',
            defaultValue: 'vinay',
            description: 'Enter user name'
        )
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/vinay592/SPE_Intelligent-Ephemeral-Multi-Stack-Dev-Platform.git'
            }
        }

        stage('Ensure Backend Running') {
            steps {
                sh '''
                echo "Checking backend..."

                if lsof -i:5001 | grep LISTEN
                then
                    echo "Backend running ✅"
                else
                    echo "Starting backend 🚀"
                    nohup python3 backend/app.py > backend.log 2>&1 &
                    sleep 5
                fi
                '''
            }
        }

        // ✅ NEW: WAIT FOR BACKEND READY
        stage('Wait for Backend Ready') {
            steps {
                sh '''
                echo "Waiting for backend..."

                for i in {1..10}
                do
                    if curl -s http://localhost:5001/ > /dev/null
                    then
                        echo "Backend ready ✅"
                        exit 0
                    fi
                    sleep 2
                done

                echo "Backend not responding ❌"
                exit 1
                '''
            }
        }

        // ✅ NEW: FRONTEND START
        stage('Ensure Frontend Running') {
    		steps {
        	sh '''
        	echo "Checking frontend..."

        	if lsof -i:3000 | grep LISTEN
        	then
            		echo "Frontend already running ✅"
        	else
            		echo "Starting frontend 🚀"
            		cd frontend
            		nohup python3 -m http.server 3000 --bind 0.0.0.0 > frontend.log 2>&1 &
            		sleep 3
        	fi
        	'''
    		}
	}

        stage('Build & Push Image') {
            steps {
                sh '''
                echo "Logging into Docker Hub..."
                echo Vinay_vb18 | docker login -u vinayvb18 --password-stdin

                echo "Building image..."
                docker build -t ${STACK}-env:v1 templates/${STACK}

                echo "Tagging image..."
                docker tag ${STACK}-env:v1 vinayvb18/${STACK}-env:v1

                echo "Pushing to Docker Hub..."
                docker push vinayvb18/${STACK}-env:v1
                '''
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                sh '''
                echo "Running Trivy scan 🔐..."
                trivy image --severity HIGH,CRITICAL ${STACK}-env:v1 || true
                '''
            }
        }

        stage('Trigger Deployment') {
            steps {
                script {
                    def response = sh(
                        script: """
                        curl -s -X POST http://localhost:5001/create-env \
                        -H "Content-Type: application/json" \
                        -d '{"stack":"${params.STACK}", "user":"${params.USER_ID}"}'
                        """,
                        returnStdout: true
                    ).trim()

                    echo "Deployment Response:"
                    echo response

                    def json = readJSON text: response
                    def port = json.access_port
                    env.APP_PORT = port
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    echo "Checking app health ❤️..."
                    sleep 5

                    sh """
                    echo "App URL:"
                    echo "http://\$(minikube ip):${APP_PORT}"
                    """
                }
            }
        }
    }

    post {
        success {
            mail to: 'vinayvb592@gmail.com',
                 subject: "SUCCESS: ${params.STACK}",
                 body: "Build + Deployment successful 🚀"
        }
        failure {
            mail to: 'vinayvb592@gmail.com',
                 subject: "FAILED: ${params.STACK}",
                 body: "Something went wrong ❌"
        }
    }
}
