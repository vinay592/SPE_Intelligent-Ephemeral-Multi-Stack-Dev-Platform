pipeline {
    agent any

    environment {
        STACK = "flask"
        USER = "test"
        IMAGE_NAME = "vinayvb18/${STACK}-env"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Clone Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/vinay592/SPE_Intelligent-Ephemeral-Multi-Stack-Dev-Platform.git'
            }
        }
 
        // ✅ ANSIBLE (SAFE VERSION)
        stage('Setup Infra (Ansible)') {
            steps {
                sh '''
                echo "Running Ansible setup..."

                # ensure docker running
                sudo systemctl start docker || true
                sudo chmod 666 /var/run/docker.sock || true

                # run ansible but don't fail pipeline
                ansible-playbook ansible/setup.yml || true
                '''
            }
        }

        // ✅ FIXED PYTHON ENV (NO PIP BUG)
        stage('Setup Backend Environment') {
            steps {
                dir('backend') {
                    sh '''
                    python3 -m venv venv

                    # REMOVE BROKEN PIP COMPLETELY
                    rm -rf venv/lib/python3.12/site-packages/pip*

                    # REINSTALL CLEAN PIP
                    curl -sS https://bootstrap.pypa.io/get-pip.py | venv/bin/python

                    # INSTALL REQUIREMENTS
                    venv/bin/pip install -r requirements.txt
                    '''
                }
            }
        }
        stage('Run Unit Tests') {
            steps {
                dir('backend') {
                    sh '''
                    # Install pytest if not present
                    ./venv/bin/pip install pytest
                    
                    # Run the professional test suite
                    echo "🧪 Running Python Unit Tests..."
                    ./venv/bin/python -m pytest tests/test_api.py -v
                    '''
                }
            }
        }

        stage('Start ELK Monitoring') {
            steps {
                sh '''
                # Preserve vault to keep the data, only cleanup others
                docker rm -f elasticsearch logstash kibana || true
                
                # Ensure vault is running without wiping it
                if ! docker ps | grep vault > /dev/null; then
                    docker-compose up -d vault
                fi
                docker-compose up -d elasticsearch logstash kibana
                '''
            }
        }

        stage('Ensure Mongo Ready') {
            steps {
                sh '''
                # ── Step 1: Seed Vault with the correct MongoDB URI ──
                # WHY localhost?
                #   The backend (app.py) runs on the HOST machine, NOT inside a K8s pod.
                #   mongo-svc is a K8s-internal DNS name — only pods inside the cluster
                #   can resolve it.  From the host, we rely on the port-forward tunnel
                #   (Step 5) which maps  localhost:27017 → mongo-svc:27017.
                #   So the URI stored here (and decoded by the backend) must be localhost.
                echo "🔑 Seeding Vault with MongoDB URI (host-accessible via port-forward)..."
                sudo docker exec -e VAULT_TOKEN=root vault \
                    vault kv put secret/mongo uri="mongodb://localhost:27017" || true

                echo "🔑 Fetching MongoDB URI from Vault..."
                VAULT_MONGO_URI=$(sudo docker exec -e VAULT_TOKEN=root vault \
                    vault kv get -field=uri secret/mongo)

                if [ -z "$VAULT_MONGO_URI" ]; then
                    echo "❌ Failed to fetch MongoDB URI from Vault!"
                    exit 1
                fi
                echo "✅ Vault returned: $VAULT_MONGO_URI"

                B64_MONGO=$(echo -n "$VAULT_MONGO_URI" | base64 -w 0)

                # ── Step 2: Generate the Kubernetes Secret from Vault value ──
                echo "🔑 Generating Dynamic k8s/secrets.yml..."
                cat <<EOF > k8s/secrets.yml
apiVersion: v1
kind: Secret
metadata:
  name: dev-platform-secrets
  namespace: dev-platform
type: Opaque
data:
  MONGO_URI: $B64_MONGO
EOF

                # ── Step 3: Apply all manifests ──
                sudo -u vinay-v-bhandare bash -ec "
                    minikube status || minikube start --driver=docker

                    kubectl get namespace dev-platform 2>/dev/null || kubectl create namespace dev-platform
                    minikube addons list | grep metrics-server | grep enabled || minikube addons enable metrics-server

                    kubectl apply -f k8s/config.yml
                    kubectl apply -f k8s/secrets.yml
                    kubectl apply -f k8s/mongo.yaml
                    kubectl apply -f k8s/resource-quota.yaml
                "

                # ── Step 4: Wait for MongoDB pod to be fully ready ──
                # Use kubectl wait for ContainersReady condition (much more reliable
                # than polling status.phase which stays 'Running' even during init).
                echo "⏳ Waiting for MongoDB pod to become ContainersReady (up to 3 min)..."
                sudo -u vinay-v-bhandare kubectl wait pod \
                    -l app=mongo \
                    -n dev-platform \
                    --for=condition=ContainersReady \
                    --timeout=180s

                if [ $? -ne 0 ]; then
                    echo "❌ MongoDB pod did not become ready in time. Pod status:"
                    sudo -u vinay-v-bhandare kubectl get pods -n dev-platform -l app=mongo -o wide
                    sudo -u vinay-v-bhandare kubectl describe pod -l app=mongo -n dev-platform | tail -30
                    exit 1
                fi
                echo "✅ MongoDB pod is ContainersReady."

                # ── Step 5: Start port-forward for backend localhost access ──
                # Kill any stale tunnels first
                sudo -u vinay-v-bhandare pkill -f "kubectl port-forward.*mongo-svc" || true
                sleep 2

                # JENKINS_NODE_COOKIE=dontKillMe prevents Jenkins from killing
                # background processes when the step ends.
                sudo -u vinay-v-bhandare bash -c \
                    "JENKINS_NODE_COOKIE=dontKillMe nohup kubectl port-forward svc/mongo-svc 27017:27017 -n dev-platform > /tmp/mongo-pf.log 2>&1 &"

                # ── Step 6: Verify the tunnel is actually accepting TCP connections ──
                # Poll up to 30s instead of a blind sleep.
                echo "⏳ Waiting for port-forward tunnel on localhost:27017..."
                for i in $(seq 1 30); do
                    if nc -z 127.0.0.1 27017 2>/dev/null; then
                        echo "✅ MongoDB port-forward is live on localhost:27017"
                        break
                    fi
                    if [ "$i" -eq 30 ]; then
                        echo "❌ Timed out waiting for port-forward. Log:"
                        cat /tmp/mongo-pf.log || true
                        exit 1
                    fi
                    echo "   Attempt $i/30 – waiting..."
                    sleep 1
                done
                '''
            }
        }

        stage('Start & Test Backend') {
            steps {
                dir('backend') {
                    sh '''
                    if sudo lsof -Pi :5002 -sTCP:LISTEN -t > /dev/null ; then
                        sudo fuser -k 5002/tcp || true
                        sleep 2
                    fi
                    
                    echo "🔐 Extracting MONGO_URI from Kubernetes Secret..."
                    DB_URL=$(sudo -u vinay-v-bhandare kubectl get secret dev-platform-secrets -n dev-platform -o jsonpath="{.data.MONGO_URI}" | base64 --decode)
                    echo "✅ Passing Secure Secret to Backend Context"
                    
                    sudo -E -u vinay-v-bhandare bash -c "export MONGO_URI=\\"$DB_URL\\" && nohup ./venv/bin/python app.py > /tmp/backend.log 2>&1 &"
                    
                    echo "⌛ Waiting 15s for backend stabilization..."
                    sleep 15
                    
                    # Core health check: verifies the app is alive and responding
                    curl -s -v http://localhost:5002/ || exit 1
                    '''
                }
            }
        }

        stage('Build & Push Changed Images') {
    steps {
        sh '''
        echo "🔑 Ensuring Vault is seeded..."
        sudo docker exec -e VAULT_TOKEN=root vault \
        vault kv put secret/docker-hub password=Vinay_vb18 || true

        echo "🔑 Fetching Docker Hub credentials..."
        DOCKER_PW=$(sudo docker exec -e VAULT_TOKEN=root vault \
        vault kv get -field=password secret/docker-hub)

        echo "$DOCKER_PW" | docker login -u vinayvb18 --password-stdin

        echo "🔍 Checking changed files..."

        CHANGED_FILES=$(git diff --name-only HEAD~1 HEAD)

        echo "$CHANGED_FILES"

        for stack in flask java mern ml; do

            if echo "$CHANGED_FILES" | grep -q "templates/${stack}/"; then
                echo "🚀 Changes detected in $stack"

                docker build \
                -t "vinayvb18/${stack}-env:latest" \
                "templates/${stack}"

                docker push "vinayvb18/${stack}-env:latest"

            else
                echo "⏭️ No changes in $stack → skipping build"
            fi

        done
        '''
    }
}

        stage('Security Scan (Trivy)') {
            steps {
                sh '''
                echo "--- Initiating Security Audit (Trivy) ---"
                for stack in flask java mern ml; do
                    echo "Scanning Image: vinayvb18/${stack}-env:latest"
                    trivy image --severity HIGH,CRITICAL --no-progress "vinayvb18/${stack}-env:latest" || true
                done
                '''
            }
        }


        stage('Deploy') {
            steps {
                sh '''
                echo "🚀 Deploying Dashboard Environment..."
                curl -X POST http://localhost:5002/create-env \
                -H "Content-Type: application/json" \
                -d '{"stack":"flask","user":"prod_user","image":"vinayvb18/flask-env:latest"}'
                '''
            }
        }
    }

    post {
        success {
            echo "SUCCESS ✅"
        }
        failure {
            echo "FAILED ❌"
        }
    }
}
