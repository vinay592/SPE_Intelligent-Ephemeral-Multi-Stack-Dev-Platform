pipeline {
    agent any

    environment {
        STACK = "flask"
        USER = "test"
        IMAGE_NAME = "vinayvb18/${STACK}-env"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Clone Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/vinay592/SPE_Intelligent-Ephemeral-Multi-Stack-Dev-Platform.git'
            }
        }
 
        // ✅ ANSIBLE (SAFE VERSION)
        stage('Setup Infra (Ansible)') {
            steps {
                sh '''
                echo "Running Ansible setup..."

                # ensure docker running
                sudo systemctl start docker || true
                sudo chmod 666 /var/run/docker.sock || true

                # run ansible but don't fail pipeline
                ansible-playbook ansible/setup.yml || true
                '''
            }
        }

        // ✅ FIXED PYTHON ENV (NO PIP BUG)
        stage('Setup Backend Environment') {
            steps {
                dir('backend') {
                    sh '''
                    python3 -m venv venv

                    # REMOVE BROKEN PIP COMPLETELY
                    rm -rf venv/lib/python3.12/site-packages/pip*

                    # REINSTALL CLEAN PIP
                    curl -sS https://bootstrap.pypa.io/get-pip.py | venv/bin/python

                    # INSTALL REQUIREMENTS
                    venv/bin/pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Start ELK Monitoring') {
            steps {
                sh '''
                # Aggressive cleanup to resolve container name conflicts
                docker rm -f vault elasticsearch logstash kibana || true
                docker-compose up -d
                '''
            }
        }

        stage('Ensure Mongo Ready') {
            steps {
                sh '''
                # Run cluster commands securely as your local user to bypass folder lockouts
                sudo -u vinay-v-bhandare bash -ec "
                    minikube status || minikube start --driver=docker

                    kubectl get namespace dev-platform || kubectl create namespace dev-platform
                    minikube addons list | grep metrics-server | grep enabled || minikube addons enable metrics-server

                    kubectl apply -f k8s/config.yml
                    kubectl apply -f k8s/secrets.yml
                    kubectl apply -f k8s/mongo.yaml
                "

                for i in {1..30}
                do
                    status=$(sudo -u vinay-v-bhandare kubectl get pods -n dev-platform -l app=mongo -o jsonpath="{.items[0].status.phase}" 2>/dev/null || echo "NotReady")

                    if [ "$status" = "Running" ]
                    then
                        echo "Mongo ready"
                        break
                    fi

                    sleep 3
                done

                sudo -u vinay-v-bhandare pkill -f "kubectl port-forward" || true

                sudo -u vinay-v-bhandare JENKINS_NODE_COOKIE=dontKillMe bash -c "nohup kubectl port-forward svc/mongo-svc 27017:27017 -n dev-platform > /tmp/mongo.log 2>&1 &"
                sleep 5
                '''
            }
        }

        stage('Start & Test Backend') {
            steps {
                dir('backend') {
                    sh '''
                    export JENKINS_NODE_COOKIE=dontKillMe
                    # Robust port cleanup: Check if port 5001 is busy, then kill it
                    if sudo lsof -Pi :5001 -sTCP:LISTEN -t > /dev/null ; then
                        echo "Port 5001 is currently occupied. Clearing it now..."
                        sudo fuser -k 5001/tcp || true
                        sleep 2
                    fi
                    
                    # start backend in background as the local user so it has kubectl rights
                    sudo -E -u vinay-v-bhandare bash -c "nohup /var/lib/jenkins/workspace/spe_project_pipeline/backend/venv/bin/python /var/lib/jenkins/workspace/spe_project_pipeline/backend/app.py > /tmp/backend.log 2>&1 &"
                    
                    # Wait for backend to fully start and bind to port
                    sleep 5
                    
                    # Check if port 5001 is listening
                    curl -s http://localhost:5001/ || true

                    curl -s -X POST http://localhost:5001/signup \
                      -H "Content-Type: application/json" \
                      -d '{"username":"testuser","password":"123"}' || true
                    
                    login_res=$(curl -s -X POST http://localhost:5001/login \
                      -H "Content-Type: application/json" \
                      -d '{"username":"testuser","password":"123"}')

                    echo "$login_res" | grep '"status": true' || exit 1
                    '''
                }
            }
        }

        stage('Build & Push Image') {
            steps {
                sh '''
                echo "Vinay_vb18" | docker login -u vinayvb18 --password-stdin
                docker build -t ${IMAGE_NAME}:latest templates/${STACK}
                docker push ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                curl -X POST http://localhost:5001/create-env \
                -H "Content-Type: application/json" \
                -d "{\\"stack\\":\\"${STACK}\\",\\"user\\":\\"${USER}\\",\\"image\\":\\"${IMAGE_NAME}:latest\\"}"
                '''
            }
        }
    }

    post {
        success {
            echo "SUCCESS ✅"
        }
        failure {
            echo "FAILED ❌"
        }
    }
}
